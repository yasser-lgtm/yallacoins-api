# YallaCoins API - Environment Configuration

# Database Configuration
# Get connection string from Supabase: Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:password@db.supabase.co:5432/postgres

# JWT Configuration
# Generate strong secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-min-32-characters

# Node Environment
NODE_ENV=development

# Server Configuration
PORT=3000

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://yallacoins-creator.manus.space,https://yallacoins-admin.manus.space
